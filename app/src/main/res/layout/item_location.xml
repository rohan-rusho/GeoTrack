<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/CardView.Styled">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_icon_container"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/primary_container"
            app:cardElevation="0dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true">
            <ImageView
                android:id="@+id/iv_item_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_location"
                app:tint="@color/primary"
                android:padding="12dp"
                android:contentDescription="Location Icon" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_toEndOf="@id/cv_icon_container"
            android:layout_marginStart="16dp"
            android:layout_toStartOf="@id/ll_item_info">

            <TextView
                android:id="@+id/tv_item_coords"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="23.8103, 90.4125"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_item_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="21 May 2025"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_item_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentEnd="true"
            android:gravity="end"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/tv_item_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:30 AM"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_item_accuracy"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="Just now"
                android:textColor="@color/white"
                android:background="@drawable/green_badge_bg"
                android:paddingHorizontal="4dp"
                android:paddingVertical="4dp"
                android:layout_marginTop="6dp"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
