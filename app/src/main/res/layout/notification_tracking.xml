<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <!-- STATUS ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <ImageView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:src="@drawable/ic_dot_green"
            app:tint="@color/notif_dot_green"
            android:layout_marginEnd="8dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tracking Active"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/notif_text_primary"
            android:forceDarkAllowed="false" />
    </LinearLayout>

    <!-- STATS ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="4"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Latitude"
                android:textSize="11sp"
                android:textColor="@color/notif_text_secondary"
                android:forceDarkAllowed="false" />
            <TextView
                android:id="@+id/tvLat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--.--"
                android:textSize="12sp"
                android:textStyle="normal"
                android:textColor="@color/notif_text_primary"
                android:forceDarkAllowed="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Longitude"
                android:textSize="11sp"
                android:textColor="@color/notif_text_secondary"
                android:forceDarkAllowed="false" />
            <TextView
                android:id="@+id/tvLng"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--.--"
                android:textSize="12sp"
                android:textStyle="normal"
                android:textColor="@color/notif_text_primary"
                android:forceDarkAllowed="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Updated"
                android:textSize="11sp"
                android:textColor="@color/notif_text_secondary"
                android:forceDarkAllowed="false" />
            <TextView
                android:id="@+id/tvUpdated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textSize="12sp"
                android:textStyle="normal"
                android:textColor="@color/notif_text_primary"
                android:forceDarkAllowed="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Interval"
                android:textSize="11sp"
                android:textColor="@color/notif_text_secondary"
                android:forceDarkAllowed="false" />
            <TextView
                android:id="@+id/tvInterval"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--m"
                android:textSize="12sp"
                android:textStyle="normal"
                android:textColor="@color/notif_text_primary"
                android:forceDarkAllowed="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- BUTTON ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="6dp">

        <LinearLayout
            android:id="@+id/btnOpenApp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/notification_button_blue"
            android:paddingVertical="8dp"
            android:gravity="center"
            android:layout_marginEnd="8dp">
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_open_app"
                android:layout_marginEnd="8dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open App"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnStopTracking"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/notif_btn_filled_red"
            android:gravity="center"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stop Tracking"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>