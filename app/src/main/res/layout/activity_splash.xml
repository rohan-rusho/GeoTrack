<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_bg_img">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="140dp"
            android:layout_height="140dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="70dp"
            app:cardElevation="8dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/logo_long"
                android:scaleType="centerCrop"
                android:contentDescription="Splash Logo" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Geo"
                android:textColor="@color/white"
                android:textSize="42sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Track"
                android:textColor="@color/success"
                android:textSize="42sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Background Location Tracking System"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:alpha="0.9" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track. Save. Secure. Always."
            android:textColor="@color/white"
            android:textSize="12sp"
            android:layout_marginTop="32dp"
            android:alpha="0.7" />

        <ProgressBar
            android:id="@+id/splash_progress"
            android:layout_width="220dp"
            android:layout_height="12dp"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_marginTop="48dp"
            android:progressDrawable="@drawable/splash_progress_bar"
            android:progress="0"
            android:max="100" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Initializing..."
            android:textColor="@color/white"
            android:textSize="12sp"
            android:layout_marginTop="12dp"
            android:alpha="0.8" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Version 1.2.1"
        android:textColor="@color/white"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"
        android:alpha="0.5"
        android:textSize="10sp" />

</RelativeLayout>
